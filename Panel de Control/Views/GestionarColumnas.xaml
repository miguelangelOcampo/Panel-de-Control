<Window x:Class="Panel_de_Control.Views.GestionarColumnas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionar Columnas"
        Height="600" Width="420"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="White" CornerRadius="12" Padding="20">

        <StackPanel>

            <!-- HEADER -->
            <Grid Margin="0,0,0,10">
                <TextBlock Text="Gestionar Columnas de la Tabla"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Button Content="✕"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        Click="Guardar_Click"/>
            </Grid>

            <TextBlock Text="Activa o desactiva las columnas que deseas visualizar"
                       Foreground="#6B7280"
                       Margin="0,0,0,15"/>

            <!-- LISTA -->
            <ScrollViewer Height="420">
                <ItemsControl x:Name="ListaColumnas">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Background="#F9FAFB"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- NOMBRE -->
                                    <TextBlock Text="{Binding Nombre}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>

                                    <!-- BOTON CHECK PARA LA ACTIVACION DE VISIBILIDAD DE LAS COLUMNAS-->
                                    <ToggleButton Grid.Column="1"
                                                  IsChecked="{Binding Activa}"
                                                  Width="45"
                                                  Height="22"
                                                  Margin="10,0,0,0">

                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="#D1D5DB"/>
                                                <Setter Property="BorderThickness" Value="0"/>

                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="bg"
                                                                    CornerRadius="11"
                                                                    Background="{TemplateBinding Background}">
                                                                <Ellipse x:Name="dot"
                                                                         Fill="White"
                                                                         Width="18"
                                                                         Height="18"
                                                                         Margin="2"/>
                                                            </Border>

                                                            <ControlTemplate.Triggers>

                                                                <!-- ACTIVO -->
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#2563EB"/>
                                                                    <Setter TargetName="dot" Property="HorizontalAlignment" Value="Right"/>
                                                                </Trigger>

                                                                <!-- INACTIVO -->
                                                                <Trigger Property="IsChecked" Value="False">
                                                                    <Setter TargetName="dot" Property="HorizontalAlignment" Value="Left"/>
                                                                </Trigger>

                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>

                                    </ToggleButton>

                                </Grid>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- BOTON -->
            <Button Content="Guardar"
                    Height="40"
                    Margin="0,10,0,0"
                    Background="#2563EB"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="Guardar_Click"/>

        </StackPanel>

    </Border>
</Window>