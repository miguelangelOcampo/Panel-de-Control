<Window x:Class="Panel_de_Control.Views.AgregarEquipo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Equipo" Height="800" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Border Background="White" CornerRadius="10" Padding="20" Margin="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="70"/>
            </Grid.RowDefinitions>

            <!-- 🔷 Título -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Agregar Nuevo Equipo"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Complete la información del equipo"
                           Foreground="Gray"
                           FontSize="12"/>
            </StackPanel>

            <!-- 🔷 Formulario -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 🔹 Columna izquierda -->
                <StackPanel Grid.Column="0">

                    <TextBlock Text="Código Activo"/>
                    <TextBox x:Name="txtCodigoActivo" Style="{StaticResource RoundedTextBox}" Tag="Ej: A192"/>

                    <TextBlock Text="Marca" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtMarca" Style="{StaticResource RoundedTextBox}" Tag="Ej: Mindray"/>
                    
                    <TextBlock Text="Modelo" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtModelo" Style="{StaticResource RoundedTextBox}" Tag="Ej: Beneheart D3"/>

                    <TextBlock Text="Numero de serie" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtSerie" Style="{StaticResource RoundedTextBox}" Tag="Ej: SN-12345"/>

                    <TextBlock Text="Ubicación" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtUbicacion" Style="{StaticResource RoundedTextBox}" Tag="Cirugía"/>

                    <TextBlock Text="Estado del equipo" Margin="0 10 0 0"/>
                    <ComboBox x:Name="cbEstado" Height="35" SelectedIndex="0" Style="{StaticResource RoundedComboBox}">
                        <ComboBoxItem Content="Operativo"/>
                        <ComboBoxItem Content="Mantenimiento"/>
                        <ComboBoxItem Content="Fuera de Servicio"/>
                        <ComboBoxItem Content="Otro"/>
                    </ComboBox>

                </StackPanel>

                <!-- 🔹 Columna derecha -->
                <StackPanel Grid.Column="2">

                    <TextBlock Text="Nombre del equipo"/>
                    <TextBox x:Name="txtNombre" Style="{StaticResource RoundedTextBox}" Tag="Ej: Desfibrilador"/>

                    <TextBlock Text="Periodicidad de mantenimiento" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtPeriodicidad" Style="{StaticResource RoundedTextBox}" Tag="Semestral"/>

                    <TextBlock Text="Último Mantenimiento" Margin="0 10 0 0"/>
                    <DatePicker x:Name="dpUltimoMantenimiento" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Calibración" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtCalibracion" Style="{StaticResource RoundedTextBox}" Tag="Anual"/>

                    <TextBlock Text="Última Calibración" Margin="0 10 0 0"/>
                    <DatePicker x:Name="dpUltimaCalibracion" Style="{StaticResource InputStyle}"/>

                    <TextBlock Text="Responsable" Margin="0 10 0 0"/>
                    <TextBox x:Name="txtResponsable" Style="{StaticResource RoundedTextBox}" Tag="Tecnico biomedico 1"/>

                    <TextBlock Text="Fecha Adquisición" Margin="0 10 0 0"/>
                    <DatePicker x:Name="dpFechaAdquisicion" Style="{StaticResource InputStyle}"/>

                </StackPanel>
            </Grid>

            <!-- 🔷 Botones -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0" Width="220">
                <Button Content="Cancelar" Width="100" Margin="5" Click="Button_Cancelar" Style="{StaticResource BaseButtonStyle}" Background="#E5E7EB"/>
                <Button Content="Guardar" Width="100" Margin="5" Style="{StaticResource BaseButtonStyle}" Click="Button_Guardar" Background="#2563EB" Foreground="White"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>