<Window x:Class="Panel_de_Control.Views.SignUp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro"
        Height="500"
        Width="500"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>

        <Border Width="350"
                Background="White"
                CornerRadius="10"
                Padding="20"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- Título -->
                    <TextBlock Text="Crear Cuenta"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre Completo"/>
                    <TextBox x:Name="txtNombre"
                             Style="{StaticResource InputTextBox}"/>

                    <!-- Correo -->
                    <TextBlock Text="Correo Electrónico"/>
                    <TextBox x:Name="txtCorreo"
                             Style="{StaticResource InputTextBox}"/>

                    <!-- Contraseña -->
                    <TextBlock Text="Contraseña"/>
                    <PasswordBox x:Name="txtPass"
                                 Height="30"
                                 Margin="0,5,0,20"/>

                    <!-- Botón -->
                    <Button Content="Crear Cuenta"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnCrear_Click"/>

                    <!-- Volver -->
                    <Button Content="Volver al Login"
                            Style="{StaticResource LinkButton}"
                            Margin="0,10,0,0"
                            Click="BtnVolver_Click"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

    </Grid>
</Window>