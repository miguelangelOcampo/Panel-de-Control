<Window x:Class="Panel_de_Control.Views.AgregarPeticion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Petición" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">
    <Border Background="White" CornerRadius="10" Padding="20" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="70"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Nueva Petición" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Complete la información de la petición" Foreground="Gray" FontSize="12"/>
            </StackPanel>

            <!-- Formulario -->
            <StackPanel Grid.Row="1" Margin="0,10">
                <TextBlock Text="Tipo de Petición"/>
                <ComboBox x:Name="cbTipo" Height="35" Style="{StaticResource RoundedComboBox}">
                    <ComboBoxItem Content="Mantenimiento"/>
                    <ComboBoxItem Content="Calibración"/>
                    <ComboBoxItem Content="Reporte de falla"/>
                    <ComboBoxItem Content="Otro"/>
                </ComboBox>

                <TextBlock Text="Descripción" Margin="0,10,0,0"/>
                <TextBox x:Name="txtDescripcion" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Style="{StaticResource RoundedTextBox}" Tag="Detalle de la petición"/>

                <TextBlock Text="Técnico Responsable" Margin="0,10,0,0"/>
                <TextBox x:Name="txtTecnico" Style="{StaticResource RoundedTextBox}" Tag="Ej: Técnico biomedico 1"/>
                
                <TextBlock Text="Técnico Responsable" Margin="0,10,0,0"/>
                <ComboBox x:Name="cbTecnico" Height="35" Style="{StaticResource RoundedComboBox}" DisplayMemberPath="Nombre" SelectedValuePath="Id"/>
            </StackPanel>

            <!-- Botones -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancelar" Width="100" Margin="5" Click="Button_Cancelar" Style="{StaticResource BaseButtonStyle}" Background="#E5E7EB"/>
                <Button Content="Guardar" Width="100" Margin="5" Style="{StaticResource BaseButtonStyle}" Click="Button_Guardar" Background="#2563EB" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>