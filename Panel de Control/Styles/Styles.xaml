<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--BotonStyle predeterminado-->
    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                     Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"
                     BorderThickness="{TemplateBinding BorderThickness}"
                     CornerRadius="8"
                     Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#00C45C"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <!-- PRESSED -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#059669"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BOTON SOLO TEXTO -->
    <Style x:Key="TextButtonStyle"
    TargetType="Button"
    BasedOn="{StaticResource BaseButtonStyle}">
        <!-- No cambia contenido, solo hereda -->
    </Style>

    <!-- ⭐ BOTON CON ICONO -->
    <Style x:Key="IconButtonStyle"
    TargetType="Button"
    BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                     Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"
                     BorderThickness="{TemplateBinding BorderThickness}"
                     CornerRadius="8"
                     Padding="{TemplateBinding Padding}">

                        <!-- AQUÍ ARMAMOS ICONO + TEXTO -->
                        <StackPanel Orientation="Horizontal"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                            <!-- ICONO DEL BOTON-->
                            <TextBlock Text="{TemplateBinding Tag}"
                                FontFamily="Segoe MDL2 Assets"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                            <!-- TEXTO DEL BOTON-->
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!--EVENTOS HOVER-->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#00C45C"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <!--EVENTO PRESIONAR BOTON-->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#059669"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--BARRA BUSCADORA-->
    <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
        <!-- Apariencia base -->
        <Setter Property="Background" Value="#F9FAFB"/>
        <Setter Property="BorderBrush" Value="#D1D5DB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="35,8,10,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#111827"/>
        <!-- Template personalizado -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">

                    <Grid>
                        <!-- BORDE -->
                        <Border x:Name="border"
                     Background="{TemplateBinding Background}"
                     BorderBrush="{TemplateBinding BorderBrush}"
                     BorderThickness="{TemplateBinding BorderThickness}"
                     CornerRadius="10"/>
                        <!-- ICONO O LUPA -->
                        <TextBlock Text="&#xE721;"
                        FontFamily="Segoe MDL2 Assets"
                        Foreground="Gray"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"/>
                        <!-- TEXTO -->
                        <ScrollViewer x:Name="PART_ContentHost"
                           Margin="30,0,0,0"/>
                        <!-- PLACEHOLDER -->
                        <TextBlock x:Name="placeholder"
                        Text="Buscar equipos..."
                        Foreground="Gray"
                        Margin="30,0,0,0"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False"/>
                    </Grid>

                    <!-- TRIGGERS O EVENTOS -->
                    <ControlTemplate.Triggers>
                        <!-- Cuando tiene texto -->
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <!-- Cuando escribe -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#2563EB"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="placeholder" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <!-- Si ya tiene texto -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocused" Value="False"/>
                                <Condition Property="Text" Value=""/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!--ESTILO PARA EL DATA GRID-->
    <Style x:Key="ModernDataGrid" TargetType="DataGrid">
        <!-- General -->
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowHeight" Value="40"/>
        <Setter Property="ColumnHeaderHeight" Value="40"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <!-- Scroll -->
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    <!--ESTILOS PARA EL AJUSTADOR DE COLUMNAS-->
    <Style x:Key="ColumnHeaderGripperStyle" TargetType="Thumb">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="SizeWE"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="grip"
                        Background="Transparent"
                        Width="6"/>
                    <ControlTemplate.Triggers>

                        <!-- HOVER -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="grip"
                                Property="Background"
                                Value="#D1D5DB"/>
                        </Trigger>

                        <!-- DRAG -->
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="grip"
                                Property="Background"
                                Value="#9CA3AF"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--HEADERS-->
    <Style x:Key="ModernDataGridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F9FAFB"/>
        <Setter Property="Foreground" Value="#374151"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="10,5"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>

                        <!-- Fondo -->
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"/>

                        <!-- Contenido -->
                        <ContentPresenter 
                            Content="{TemplateBinding Content}"
                            Margin="10,0"
                            VerticalAlignment="Center"/>

                        <!-- GRIPPER IZQUIERDO -->
                        <Thumb x:Name="PART_LeftHeaderGripper"
                           Style="{StaticResource ColumnHeaderGripperStyle}"
                           HorizontalAlignment="Left"/>

                        <!-- GRIPPER DERECHO -->
                        <Thumb x:Name="PART_RightHeaderGripper"
                           Style="{StaticResource ColumnHeaderGripperStyle}"
                           HorizontalAlignment="Right"/>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!--FILAS-->
    <Style x:Key="ModernDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F9FAFB"/>
            </Trigger>

            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E0F2FE"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--CELDAS-->
    <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- Colores -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="BackgroundColor">#F3F4F6</Color>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="#2563EB"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- Botón secundario -->
    <Style x:Key="LinkButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="RoyalBlue"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- TextBox -->
    <Style x:Key="InputTextBox" TargetType="TextBox">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="0,5,0,10"/>
        <Setter Property="Padding" Value="5"/>
    </Style>

</ResourceDictionary>